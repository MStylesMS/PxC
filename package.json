{
  "name": "houdini-clock",
  "version": "1.1.1",
  "description": "React-based countdown clock interface for Houdini escape room with MQTT control",
  "private": true,
  "keywords": [
    "escape-room",
    "countdown-clock",
    "mqtt",
    "react",
    "real-time",
    "paradox"
  ],
  "author": "Paradox Escape Rooms",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paradox/houdini-clock.git"
  },
  "bugs": {
    "url": "https://github.com/paradox/houdini-clock/issues"
  },
  "homepage": ".",
  "dependencies": {
    "cross-env": "^7.0.3",
    "fbemitter": "^3.0.0",
    "ini": "^5.0.0",
    "paho-mqtt": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "^5.0.1",
    "react-transition-group": "^4.4.5",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "prettier": "^3.3.3"
  },
  "scripts": {
  "prebuild": "node scripts/generate-runtime-config.js",
  "start": "cross-env PUBLIC_URL=/ REACT_APP_MQTT_HOST=localhost REACT_APP_MQTT_PORT=1884 react-scripts start",
  "build": "cross-env REACT_APP_MQTT_HOST=localhost REACT_APP_MQTT_PORT=1884 react-scripts build",
    "build:analyze": "npm run build && npx serve -s build",
    "build:stats": "npm run build && npx webpack-bundle-analyzer build/static/js/*.js",
    "build:size": "npm run build && npx bundlesize",
    "test": "react-scripts test",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,json,css,md}",
    "format:check": "prettier --check src/**/*.{js,jsx,ts,tsx,json,css,md}",
    "perf:audit": "lighthouse http://localhost:3000 --output=html --output-path=./performance-report.html",
  "perf:profile": "npm run build && npx serve -s build & sleep 5 && npx lighthouse http://localhost:3000",
  "optimize:images": "npx imagemin src/**/*.{jpg,jpeg,png,gif,svg} --out-dir=src/optimized-images",
  "smoke:visual": "bash scripts/visual-smoke.sh"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "react-hooks/exhaustive-deps": "warn",
      "react-hooks/rules-of-hooks": "error",
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "no-console": [
        "warn",
        {
          "allow": [
            "warn",
            "error",
            "debug"
          ]
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
