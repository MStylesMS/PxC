{
  "mqtt": {
    "host": "localhost",
    "port": 1884,
    "topic": "paradox/houdini/clock",
    "reconnect_interval": 5000,
    "keep_alive": 60
  },
  "display": {
    "fade_duration_default": 2000,
    "hint_duration_default": 15,
    "clock_orientation": -90,
    "seconds_tick_style": "off"
  },
  "enable_console_logging": false
}