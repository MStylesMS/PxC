# Development Environment Configuration
NODE_ENV=development

# MQTT Settings
MQTT_HOST=localhost
MQTT_PORT=1884
MQTT_WS_PORT=9001

# Application Settings
APP_PORT=3000
REACT_APP_MQTT_HOST=localhost
REACT_APP_MQTT_PORT=1884
REACT_APP_DEBUG=true

# Development Tools
GENERATE_SOURCEMAP=true
ESLINT_NO_DEV_ERRORS=false
FAST_REFRESH=true

# Redis (optional)
REDIS_PORT=6379
