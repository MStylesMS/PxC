# Production Environment Configuration
NODE_ENV=production

# MQTT Settings (update with actual production values)
MQTT_HOST=production-mqtt-broker.com
MQTT_PORT=8883
MQTT_WS_PORT=9001

# Application Settings
APP_PORT=80
REACT_APP_MQTT_HOST=production-mqtt-broker.com
REACT_APP_MQTT_PORT=8883
REACT_APP_DEBUG=false

# Build Optimization
GENERATE_SOURCEMAP=false
INLINE_RUNTIME_CHUNK=false

# Security
HTTPS=true

# Redis (optional)
REDIS_PORT=6379
